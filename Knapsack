#include <bits/stdc++.h>
using namespace std;

struct Item {
    int value, weight;
};

// Node structure
struct Node {
    int level, profit, weight;
    float bound;
};

// Compare items by value/weight ratio
bool cmp(Item a, Item b) {
    return (double)a.value/a.weight > (double)b.value/b.weight;
}

// Calculate bound (upper limit)
float bound(Node u, int n, int W, Item arr[]) {
    if (u.weight >= W)
        return 0;

    float profit_bound = u.profit;
    int j = u.level + 1;
    int totweight = u.weight;

    // Add items while possible
    while (j < n && totweight + arr[j].weight <= W) {
        totweight += arr[j].weight;
        profit_bound += arr[j].value;
        j++;
    }

    // Add fractional item
    if (j < n)
        profit_bound += (W - totweight) * 
                        ((double)arr[j].value / arr[j].weight);

    return profit_bound;
}

// Branch and Bound Knapsack
int knapsack(int W, Item arr[], int n) {
    sort(arr, arr + n, cmp);

    queue<Node> Q;
    Node u, v;

    u.level = -1;
    u.profit = u.weight = 0;
    Q.push(u);

    int maxProfit = 0;

    while (!Q.empty()) {
        u = Q.front();
        Q.pop();

        if (u.level == n - 1)
            continue;

        v.level = u.level + 1;

        // Include item
        v.weight = u.weight + arr[v.level].weight;
        v.profit = u.profit + arr[v.level].value;

        if (v.weight <= W && v.profit > maxProfit)
            maxProfit = v.profit;

        v.bound = bound(v, n, W, arr);

        if (v.bound > maxProfit)
            Q.push(v);

        // Exclude item
        v.weight = u.weight;
        v.profit = u.profit;
        v.bound = bound(v, n, W, arr);

        if (v.bound > maxProfit)
            Q.push(v);
    }

    return maxProfit;
}

int main() {
    int n = 4;
    int W = 10;

    Item arr[] = {{10, 2}, {5, 3}, {15, 5}, {7, 7}};

    cout << "Maximum profit: " 
         << knapsack(W, arr, n);

    return 0;
}
